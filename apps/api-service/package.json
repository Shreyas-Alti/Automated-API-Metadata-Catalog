{
  "name": "@api-catalog/api-service",
  "version": "0.1.0",
  "private": true,
  "description": "Thin HTTP layer — no business logic. Submission, job status, review, publish, catalog browse.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts"
  },
  "dependencies": {
    "@api-catalog/contracts": "workspace:*",
    "@api-catalog/database": "workspace:*",
    "@api-catalog/canonical-graph": "workspace:*",
    "@api-catalog/extraction-run-tracker": "workspace:*",
    "@api-catalog/audit-log": "workspace:*",
    "@api-catalog/generator-openapi": "workspace:*",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.0.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "bullmq": "^5.0.0",
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/passport-jwt": "^4.0.0"
