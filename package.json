{
  "name": "api-metadata-catalog",
  "version": "0.0.1",
  "private": true,
  "description": "Automated API Metadata Catalog — monorepo root",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint . --ext .ts",
    "arch:lint": "depcruise --config .dependency-cruiser.js packages apps",
    "test:unit": "pnpm -r --parallel run test",
    "test:integration": "echo 'No integration tests in Phase 0'",
    "test:golden": "echo 'No golden-repo tests in Phase 0'",
    "infra:init": "powershell -ExecutionPolicy Bypass -File scripts/infra-init.ps1",
    "infra:start": "powershell -ExecutionPolicy Bypass -File scripts/infra-start.ps1",
    "infra:stop": "powershell -ExecutionPolicy Bypass -File scripts/infra-stop.ps1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "dependency-cruiser": "^16.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.4.0"
  }
}
