{
  "name": "@api-catalog/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, generated client, and shared DB utilities. The only package that directly imports @prisma/client.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "node -e \"try{require('child_process').execSync('prisma generate --schema=prisma/schema.prisma',{stdio:'inherit'})}catch(e){}\" && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0"
  },
  "devDependencies": {
    "prisma": "^5.0.0"
  }
}
