# Local dev environment variables — copy to .env (never commit .env)

# Postgres (started via pnpm run infra:start)
DATABASE_URL=postgresql://api_catalog@localhost:5432/api_catalog
DATABASE_TEST_URL=postgresql://api_catalog@localhost:5432/api_catalog_test

# Redis / BullMQ (started via pnpm run infra:start)
REDIS_URL=redis://localhost:6379

# MinIO — S3-compatible local storage (started via pnpm run infra:start)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_dev
S3_BUCKET=api-catalog

# Service ports
API_SERVICE_PORT=3000
WORKER_SERVICE_PORT=3001
AUTH_SERVICE_PORT=3002
